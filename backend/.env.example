# JARVIS Backend Environment Configuration

# Server Configuration
PORT=18789
NODE_ENV=development
HOST=0.0.0.0

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# AI Providers
# OpenAI - Get key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude - Get key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini - Get key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Messaging Integrations (Optional)
WHATSAPP_API_KEY=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=

# Voice Synthesis (Optional)
ELEVEN_LABS_API_KEY=
GOOGLE_CLOUD_TTS_KEY=

# Security
JWT_SECRET=your-secret-key-change-in-production-12345
ENCRYPTION_KEY=your-32-character-encryption-key-for-aes

# Database (Optional)
MONGODB_URI=mongodb://localhost:27017/jarvis

# Desktop Automation (Optional)
ROBOTJS_ENABLED=false
PUPPETEER_ENABLED=false

# Logging
LOG_LEVEL=info
LOG_FILE=logs/jarvis.log
